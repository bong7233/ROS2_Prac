<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="amr_demo_robot">
  <xacro:property name="base_length" value="0.82"/>
  <xacro:property name="base_width" value="0.58"/>
  <xacro:property name="base_height" value="0.24"/>
  <xacro:property name="wheel_radius" value="0.10"/>
  <xacro:property name="wheel_width" value="0.065"/>
  <xacro:property name="wheel_y" value="0.335"/>

  <material name="base_blue">
    <color rgba="0.13 0.28 0.48 1.0"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.03 0.04 0.05 1.0"/>
  </material>
  <material name="lidar_black">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="base_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 ${wheel_y} -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -${wheel_y} -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_caster">
    <visual>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.33 0 -0.065" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.055" length="0.07"/>
      </geometry>
      <material name="lidar_black"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.23 0 0.175" rpy="0 0 0"/>
  </joint>

  <!-- Forward-facing docking camera. camera_link is the mounting frame;
       camera_optical_frame follows the REP-103 optical convention
       (x right, y down, z forward) used by amr_vision. -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.03 0.09 0.03"/>
      </geometry>
      <material name="lidar_black"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.40 0 0.10" rpy="0 0 0"/>
  </joint>

  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>
</robot>

